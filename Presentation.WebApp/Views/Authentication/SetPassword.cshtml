@using Presentation.WebApp.Models.Authentication
@model SetPasswordForm

@{
    Layout = "Layouts/_AuthLayout";
    ViewData["Title"] = "Set Password";
}

<section class="_auth">
    <div class="signin-container">
        <form class="signin-form" method="post" asp-action="SetPassword" asp-controller="Authentication" novalidate>
            @Html.AntiForgeryToken()

            <div class="title">
                <h1>Set Your Password</h1>
                <p class="description">Set a strong password to protect your account. Your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.</p>
                <hr />
            </div>

            <div class="form-grid-fields">
                <div data-id="password" class="form-group">
                    <label class="form-label" asp-for="Password"></label>
                    <input class="form-input" type="password" asp-for="Password" placeholder="@Html.DisplayNameFor(m => m.Password)" />
                    <span class="field-validation" asp-validation-for="Password"></span>
                </div>

                <div data-id="confirm-password" class="form-group">
                    <label class="form-label" asp-for="ConfirmPassword"></label>
                    <input class="form-input" type="password" asp-for="ConfirmPassword" placeholder="@Html.DisplayNameFor(m => m.ConfirmPassword)" />
                    <span class="field-validation" asp-validation-for="ConfirmPassword"></span>
                </div>
            </div>

            <button class="btn" type="submit">Continue</button>

            <div class="form-errormessage">
                <div asp-validation-summary="ModelOnly" class="field-validation-error"></div>
                <span class="field-validation-error" asp-validation-for="ErrorMessage"></span>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="~/Views/Shared/Partials/Globals/_ValidationScripts.cshtml" />
}