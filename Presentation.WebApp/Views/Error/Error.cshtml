@model ErrorViewModel

<section class="page-header">
    <div class="container">
        <partial name="Partials/Globals/_PageTitleSection" />
    </div>
</section>

<div class="page_error container">
    <section class="error-content">
        <img src="~/images/404-error-img.png" alt="Error Illustration">
        <div class="error-info">
            @if (Model.StatusCode == 404)
            {
                <h2>Oops! Page not found.</h2>
                <p>The page you're looking for does not exist.</p>
            }
            else
            {
                <h2>Oops! An unexpected error occurred.</h2>
                <p>Our technicians have been notified and are working to resolve the issue as quickly as possible.</p>
            }
            <a asp-controller="Home" asp-action="Index" class="btn">Back to Homepage</a>
        </div>
    </section>
</div>