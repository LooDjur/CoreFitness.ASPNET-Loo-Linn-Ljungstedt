@model AccountViewModel

@{
    var activeView = ViewData["ActiveView"]?.ToString()?.ToLower() ?? "about-me";

    ViewData["Title"] = "My Account";
    ViewData["PageClass"] = "about-me-page";
}

<section class="page-header">
    <div class="container">
        <partial name="Partials/Globals/_PageTitleSection" />
    </div>
</section>

<div class="about-me-page">
    <div class="container account-layout">
        <aside class="account-sidebar">
            <partial name="Partials/_AccountMenu" />
        </aside>
        <section class="account-main">
            @if (activeView == "about-me")
            {
                <partial name="Partials/_AboutMeFormSection" model="Model.Profile" />
            }
            else if (activeView == "my-membership")
            {
                <partial name="Partials/_MyMembership" model="Model.Membership" />
            }
            <partial name="Partials/_AccountStatistics" />
        </section>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/Partials/Globals/_ValidationScripts.cshtml" />
}