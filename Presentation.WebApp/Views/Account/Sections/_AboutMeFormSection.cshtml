@using Presentation.WebApp.Models.Account
@model AboutMeFormSection

@{
    ViewData["Title"] = "About Me";
}
<section class="aboutme-details">
    <form id="aboutme-form" method="post" asp-action="UpdateDetails" asp-controller="Account" novalidate>
        
        <div class=title>
            <h3>About Me</h3>
        </div>

        <div class="form-grid-fields">
            <div class="form-group">
                <label class="form-label" asp-for="FirstName"></label>
                <input class="form-input" asp-for="FirstName" />
                <span class="field-validation-error" asp-validation-for="FirstName"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="LastName"></label>
                <input class="form-input" asp-for="LastName" />
                <span class="field-validation-error" asp-validation-for="LastName"></span>
            </div>
        </div>

        <div class="form-grid-fields">
            <div class="form-group">
                <label class="form-label" asp-for="Email"></label>
                <input class="form-input" asp-for="Email" />
                <span class="field-validation-error" asp-validation-for="Email"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Phone"></label>
                <input class="form-input" asp-for="Phone" />
                <span class="field-validation-error" asp-validation-for="Phone"></span>
            </div>
        </div>

        <div class="aboutme-form-buttons" style="display: flex; gap: 1rem; margin-top: 1rem;">
            <button class="btn" type="submit">Save</button>
        </div>
    </form>
</section>